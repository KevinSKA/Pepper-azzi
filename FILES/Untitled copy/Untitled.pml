<?xml version="1.0" encoding="UTF-8" ?>
<Package name="Untitled" format_version="4">
    <Manifest src="manifest.xml" />
    <BehaviorDescriptions>
        <BehaviorDescription name="behavior" src="translations" xar="behavior.xar" />
    </BehaviorDescriptions>
    <Dialogs>
        <Dialog name="ExampleDialog" src="behavior_1/ExampleDialog/ExampleDialog.dlg" />
        <Dialog name="Greetings" src="Greetings/Greetings.dlg" />
        <Dialog name="test" src="test/test.dlg" />
    </Dialogs>
    <Resources>
        <File name="WhatIsAI" src="html/WhatIsAI.jpg" />
        <File name="assistant" src="html/assistant.jpg" />
        <File name="conclusion" src="html/conclusion.jpg" />
        <File name="example" src="html/example.jpg" />
        <File name="intro" src="html/intro.jpg" />
        <File name="lebanon" src="html/lebanon.jpg" />
        <File name="mind" src="html/mind.jpg" />
        <File name="panic" src="html/panic.jpg" />
        <File name="scare" src="html/scare.jpg" />
        <File name="viewer" src="html/viewer.html" />
    </Resources>
    <Topics>
        <Topic name="ExampleDialog_enu" src="behavior_1/ExampleDialog/ExampleDialog_enu.top" topicName="ExampleDialog" language="en_US" />
        <Topic name="Greetings_enu" src="Greetings/Greetings_enu.top" topicName="Greetings" language="en_US" />
        <Topic name="test_enu" src="test/test_enu.top" topicName="test" language="en_US" />
    </Topics>
    <IgnoredPaths />
    <Translations auto-fill="en_US">
        <Translation name="translation_en_US" src="translations/translation_en_US.ts" language="en_US" />
    </Translations>
</Package>
